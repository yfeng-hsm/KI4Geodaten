# Create a Mapillary access token in the Mapillary developer dashboard.
MAPILLARY_ACCESS_TOKEN=

# Cache successful API responses so repeated grid requests do not consume quota.
MAPILLARY_CACHE_TTL_SECONDS=86400
MAPILLARY_MAX_IMAGES_PER_GRID=2000

# Local PostGIS service. The defaults match compose.yaml.
POSTGRES_DB=ki4geodaten
POSTGRES_USER=ki4geodaten
POSTGRES_PASSWORD=ki4geodaten
DATABASE_URL=postgresql://ki4geodaten:ki4geodaten@db:5432/ki4geodaten

# Remote Ollama server reachable from the host and, ideally, from Docker.
OLLAMA_BASE_URL=http://100.87.51.96:11434
OLLAMA_MODEL=gemma4:26b
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_MAX_IMAGES_PER_REQUEST=20
OLLAMA_IMAGE_THUMB_SIZE=512
OLLAMA_CONCURRENCY=4

# Optional GraphHopper service for sequence-level map matching.
# The blue matched trajectory appears only when this is configured and reachable from Docker.
GRAPHHOPPER_BASE_URL=http://graphhopper:8989
GRAPHHOPPER_TIMEOUT_SECONDS=30
GRAPHHOPPER_REF=master

# Optional Valhalla service for alternative sequence-level map matching.
# Point this to a Valhalla instance with Mainz tiles, for example http://valhalla:8002.
VALHALLA_BASE_URL=http://valhalla:8002
VALHALLA_TIMEOUT_SECONDS=30
VALHALLA_TILE_URLS=https://download.geofabrik.de/europe/germany/rheinland-pfalz-latest.osm.pbf
VALHALLA_SERVER_THREADS=4
VALHALLA_USE_TILES_IGNORE_PBF=False
VALHALLA_FORCE_REBUILD=False
VALHALLA_BUILD_ELEVATION=False
VALHALLA_BUILD_ADMINS=False
VALHALLA_BUILD_TIME_ZONES=False
VALHALLA_BUILD_TRANSIT=False
VALHALLA_BUILD_TAR=True
